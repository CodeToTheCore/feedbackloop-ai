# Copy this file to .env and adjust for your environment.
# Not required for local dev -- SQLite is the default with zero config.

# Uncomment to use Postgres instead of the default local SQLite file:
# DATABASE_URL=postgresql://user:password@host:5432/feedbackloop

# Anthropic API -- powers the LLM-written ranking rationale (generate_rationale).
# If unset, the app falls back to v1's deterministic template rationale, so the
# demo still runs with zero config. Set this to enable the new feature.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-5
